# =============================================================================
# OSINT Platform Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# =============================================================================
# Database
# =============================================================================
# Async driver for FastAPI (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/osint

# Sync driver for Alembic migrations
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/osint

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Clerk Authentication
# =============================================================================
# Get these from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# =============================================================================
# LLM Configuration
# =============================================================================
# OpenAI API key for direct access
OPENAI_API_KEY=sk-xxx

# LiteLLM model selection
LITELLM_MODEL=gpt-4-turbo

# Optional: Other LLM providers
# ANTHROPIC_API_KEY=sk-ant-xxx
# AZURE_OPENAI_API_KEY=xxx
# AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# API Settings
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Frontend (Vite)
# =============================================================================
# These are prefixed with VITE_ to be exposed to the frontend
VITE_API_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# =============================================================================
# Celery / Background Tasks
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# Rate Limiting (Story 1.5)
# =============================================================================
# Tier-based rate limits (requests per hour)
# free=100, pro=1000, business=10000, enterprise=50000
# These are defined in app/core/middleware/rate_limit.py

# =============================================================================
# Anti-Abuse Controls (Story 1.5)
# =============================================================================
# Comma-separated list of blocked consumer email domains
# Users with these email domains cannot sign up (business email required)
BLOCKED_EMAIL_DOMAINS=gmail.com,yahoo.com,hotmail.com,outlook.com,protonmail.com,icloud.com,mail.com,aol.com,yandex.com,qq.com,163.com,live.com

# IP account limit: maximum accounts that can be created from a single IP
# Default: 3 accounts per IP (30-day window)
# IP_ACCOUNT_LIMIT=3

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_QUICK_CHECK=true
ENABLE_GRAPH_VISUALIZATION=true
ENABLE_AI_HYPOTHESIS=true

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# External Services (Optional)
# =============================================================================
# WHOIS API
# WHOIS_API_KEY=xxx

# Corporate Registry APIs
# OPENCORPORATES_API_KEY=xxx

# =============================================================================
# Monitoring (Production)
# =============================================================================
# SENTRY_DSN=https://xxx@sentry.io/xxx
# DATADOG_API_KEY=xxx
